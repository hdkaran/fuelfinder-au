{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "baseName": {
      // The short prefix used for naming all Azure resources.
      // e.g. "fuelfinder" → App Service = "fuelfinder-api", SQL server = "fuelfindersql", ACR = "fuelfindercr"
      // Must be lowercase, no spaces, ≤13 chars to avoid hitting Azure name-length limits.
      "value": "fuelfinder"
    },
    "location": {
      // Azure region. "australiaeast" = Sydney. Other options: "australiasoutheast" (Melbourne).
      // See: az account list-locations --output table
      "value": "eastasia"
    },
    "environment": {
      // Environment label — used as a tag on all resources.
      // Allowed values: "prod" | "staging" | "dev"
      "value": "prod"
    },
    "customDomain": {
      // Frontend apex domain — served by Azure Static Web Apps.
      // DNS is managed in GoDaddy — see docs/dns-setup.md for record values.
      // Leave empty on first deploy; set after GoDaddy records are added.
      "value": "fuelstock.com.au"
    },
    "customDomainApi": {
      // API subdomain — served by Azure App Service.
      // GoDaddy CNAME: api → <appServiceHostname> output from first deploy.
      // Leave empty on first deploy; set after the CNAME is added in GoDaddy.
      "value": "api.fuelstock.com.au"
    }
  }
}
