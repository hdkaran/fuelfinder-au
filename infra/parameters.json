{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "baseName": {
      // The short prefix used for naming all Azure resources.
      // e.g. "fuelfinder" → App Service = "fuelfinder-api", SQL server = "fuelfindersql", ACR = "fuelfindercr"
      // Must be lowercase, no spaces, ≤13 chars to avoid hitting Azure name-length limits.
      "value": "fuelfinder"
    },
    "location": {
      // Azure region. "australiaeast" = Sydney. Other options: "australiasoutheast" (Melbourne).
      // See: az account list-locations --output table
      "value": "eastasia"
    },
    "environment": {
      // Environment label — used as a tag on all resources.
      // Allowed values: "prod" | "staging" | "dev"
      "value": "prod"
    },
    "customDomain": {
      // Frontend apex domain — served by Azure Static Web Apps.
      // DNS: alias A record @ → SWA resource ID (handled by dns.bicep).
      // Leave empty on first deploy; set after getting Azure nameservers and updating registrar.
      "value": "fuelstock.com.au"
    },
    "customDomainApi": {
      // API subdomain — served by Azure App Service.
      // DNS: CNAME api → App Service default hostname (handled by dns.bicep).
      // Pre-requisite: deploy without this first, add the CNAME, then set this value.
      "value": "api.fuelstock.com.au"
    },
    "swaValidationToken": {
      // SWA domain ownership token — get from Azure Portal → Static Web App → Custom domains.
      // Set and re-deploy to provision the asuid TXT record for SSL cert validation.
      "value": ""
    }
  }
}
