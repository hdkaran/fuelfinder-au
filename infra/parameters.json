{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "baseName": {
      // The short prefix used for naming all Azure resources.
      // e.g. "fuelfinder" → App Service = "fuelfinder-api", SQL server = "fuelfindersql", ACR = "fuelfindercr"
      // Must be lowercase, no spaces, ≤13 chars to avoid hitting Azure name-length limits.
      "value": "fuelfinder"
    },
    "location": {
      // Azure region. "australiaeast" = Sydney. Other options: "australiasoutheast" (Melbourne).
      // See: az account list-locations --output table
      "value": "eastasia"
    },
    "environment": {
      // Environment label — used as a tag on all resources.
      // Allowed values: "prod" | "staging" | "dev"
      "value": "prod"
    },
    "customDomain": {
      // Frontend apex domain (e.g. "fuelstock.com.au").
      // IMPORTANT: Leave empty until GoDaddy DNS records are in place (see docs/dns-setup.md).
      // Azure validates DNS before binding — deploying with a value before DNS exists will fail.
      // Set via GitHub Actions variable CUSTOM_DOMAIN instead of editing this file.
      "value": ""
    },
    "customDomainApi": {
      // API subdomain (e.g. "api.fuelstock.com.au").
      // IMPORTANT: Leave empty until the GoDaddy CNAME for 'api' is added.
      // Set via GitHub Actions variable CUSTOM_DOMAIN_API instead of editing this file.
      "value": ""
    }
  }
}
