      "/suburbs/nsw/newcastle",
      "/suburbs/nsw/wollongong",
      "/suburbs/nsw/penrith",
      "/suburbs/nsw/blacktown",
      "/suburbs/nsw/liverpool",
      "/suburbs/nsw/campbelltown",
      "/suburbs/nsw/gosford",
      "/suburbs/nsw/maitland",
      "/suburbs/vic/geelong",
      "/suburbs/vic/ballarat",
      "/suburbs/vic/bendigo",
      "/suburbs/vic/frankston",
      "/suburbs/vic/dandenong",
      "/suburbs/vic/ringwood",
      "/suburbs/vic/sunshine",
      "/suburbs/qld/gold-coast",
      "/suburbs/qld/sunshine-coast",
      "/suburbs/qld/townsville",
      "/suburbs/qld/cairns",
      "/suburbs/qld/toowoomba",
      "/suburbs/qld/ipswich",
      "/suburbs/qld/mackay",
      "/suburbs/qld/rockhampton",
      "/suburbs/wa/mandurah",
      "/suburbs/wa/joondalup",
      "/suburbs/wa/fremantle",
      "/suburbs/wa/rockingham",
      "/suburbs/wa/bunbury",
      "/suburbs/sa/glenelg",
      "/suburbs/sa/elizabeth",
      "/suburbs/sa/mount-gambier",
      "/suburbs/sa/whyalla",
      "/suburbs/act/belconnen",
      "/suburbs/act/tuggeranong",
      "/suburbs/tas/hobart",
      "/suburbs/tas/launceston",
      "/suburbs/tas/devonport",
      "/suburbs/nt/darwin",
      "/suburbs/nt/alice-springs",
      "/suburbs/nt/palmerston"
